// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization{
  organization_id String @id @default(uuid())
  organization_name String 
  organization_email String @unique 
  industry_type String
  country String
  preferred_language String
  admin Admin[]
  user User[]
  lead Lead[]
  opportunity Opportunity[]
  services Services[]
  order Order[]
}
model Services{
  service_id String @id @default(uuid())
  organization_id String
  service_name String 
  service_code String
  service_category String
  service_description String
  service_price Int?
  organization Organization @relation(fields: [organization_id], references: [organization_id])
  orderitem OrderItem[] 

}
model Admin{
  admin_id String @id @default(uuid())
 admin_name String
  admin_email String @unique
  admin_password String
  organization_id String 
  organization Organization @relation(fields: [organization_id], references: [organization_id])
}

model User{
  user_id String @id @default(uuid())
  organization_id String
  full_name String 
  email String  @unique
  password String 
  employee_id String @unique
  sales_region String
  preferred_language String
  role String @default("Sales Executive")
  organization Organization @relation(fields: [organization_id], references: [organization_id])
  
}
model Lead{
  organization_id String 
  lead_id String @id @default(uuid())
  Name String
  salutation String
  title String
  description String
  lead_status String
  lead_creator String 
  phone String 
  email String 
  address String 
  source  String
  createdAt DateTime @default(now())
  organization Organization @relation(fields: [organization_id], references: [organization_id])
  opportunity Opportunity[]
  order Order[]
}

model Opportunity{
  opportunity_id String @id @default(uuid())
  organization_id String 
  lead_id String
  opportunity_name String
  title String?
  closing_date DateTime?
  amount  Decimal @db.Decimal(10,2)
  description String
  stage String
  probability Int
  forecast_category String
  next_step String
  organization Organization @relation(fields: [organization_id], references: [organization_id])
  lead Lead @relation(fields: [lead_id], references: [lead_id])
  order Order[]
}

model Order{
  order_id String @id @default(uuid())
  organization_id String
  opportunity_id String
  lead_id String
 
  order_date DateTime @default(now())
  delivery_date DateTime?

  order_status String @default("Pending")
  payment_status String @default("Unpaid")

  subtotal Int
  tax Int
  discount Int
  total_amount Int

  notes String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [organization_id])
  opportunity Opportunity @relation(fields: [opportunity_id], references: [opportunity_id])
  lead Lead @relation(fields: [lead_id], references: [lead_id])
  orderItems OrderItem[]
  
}

model OrderItem{
  item_id String @id @default(uuid())

  order_id String
  service_id String

  quantity Int
  unit_price Int
  total_price Int

  order Order @relation(fields: [order_id], references: [order_id])
  services Services @relation(fields: [service_id], references: [service_id])
  
}